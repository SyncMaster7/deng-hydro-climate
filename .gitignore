# =============================================================================
# deng-hydro-climate — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Environment & secrets — NEVER commit these
# -----------------------------------------------------------------------------
.env
*.env
.env.local
.env.*.local
datahub/user.props

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
pip-wheel-metadata/
*.egg

# Virtual environments
.venv/
venv/
env/
ENV/

# -----------------------------------------------------------------------------
# dbt
# -----------------------------------------------------------------------------
dbt_project/target/
dbt_project/dbt_packages/
dbt_project/logs/
dbt_project/.user.yml

# -----------------------------------------------------------------------------
# Airflow
# -----------------------------------------------------------------------------
logs/
airflow.cfg
airflow.db
standalone_admin_password.txt
webserver_config.py

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
# Don't ignore docker-compose.yml — that's project code
# DO ignore any local override files
docker-compose.override.yml

# -----------------------------------------------------------------------------
# macOS
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# -----------------------------------------------------------------------------
# Windows
# -----------------------------------------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# JetBrains (PyCharm)
# -----------------------------------------------------------------------------
.idea/
*.iml
*.iws
*.ipr

# -----------------------------------------------------------------------------
# VS Code
# -----------------------------------------------------------------------------
.vscode/
*.code-workspace

# -----------------------------------------------------------------------------
# Jupyter (just in case)
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# -----------------------------------------------------------------------------
# Logs and temporary files
# -----------------------------------------------------------------------------
*.log
*.tmp
*.bak
*.swp
*.swo
