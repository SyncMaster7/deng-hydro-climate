# deng-hydro-climate — .env.example
# Copy to .env and fill in real values. Never commit .env to Git.

# ---------------------------------------------------------------------------
# Analytics database (application data)
# ---------------------------------------------------------------------------
ANALYTICS_DB_USER=deng
ANALYTICS_DB_PASSWORD=changeme
ANALYTICS_DB_NAME=hydro_climate

# ---------------------------------------------------------------------------
# Airflow metadata database (Airflow internals only)
# ---------------------------------------------------------------------------
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=changeme
AIRFLOW_DB_NAME=airflow

# ---------------------------------------------------------------------------
# Airflow security keys
# Generate FERNET_KEY with:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Generate SECRET_KEY with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# ---------------------------------------------------------------------------
AIRFLOW_FERNET_KEY=changeme
AIRFLOW_SECRET_KEY=changeme

# ---------------------------------------------------------------------------
# Airflow admin user (created on first init)
# ---------------------------------------------------------------------------
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=changeme
AIRFLOW_ADMIN_EMAIL=your@email.com

# ---------------------------------------------------------------------------
# Airflow UID — match your server user to avoid volume permission issues
# Find with: id -u
# ---------------------------------------------------------------------------
AIRFLOW_UID=1000
